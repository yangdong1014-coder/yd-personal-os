# DeepSeek API Key（必填，否则 AI 功能不可用）
DEEPSEEK_API_KEY=your_key_here

# API 地址（可选，默认 https://api.deepseek.com/v1）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 默认模型（可选；若设置则锁定 AI管理页的模型选择）
# 可选值：deepseek-v4-flash / deepseek-v4-pro / deepseek-chat / deepseek-reasoner
# DEEPSEEK_MODEL=deepseek-v4-pro

# 请求超时秒数（可选，默认 60）
# DEEPSEEK_TIMEOUT=60

# --- 家庭服务器远程访问（v1.13+，可选）---
# 启用远程访问模式：非本机访问必须携带访问令牌
# PERSONAL_OS_REMOTE=1
# PERSONAL_OS_ACCESS_TOKEN=请替换为长随机字符串

# 显式绑定地址（默认 127.0.0.1；仅在 REMOTE=1 时允许非 localhost）
# 推荐仍用 127.0.0.1 + Tailscale Serve，不建议公网暴露
# PERSONAL_OS_BIND_HOST=127.0.0.1